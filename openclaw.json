{
  "meta": {
    "lastTouchedVersion": "2026.3.13",
    "lastTouchedAt": "2026-03-16T15:22:19.128Z"
  },
  "wizard": {
    "lastRunAt": "2026-03-16T15:18:05.687Z",
    "lastRunVersion": "2026.3.13",
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      },
      "openai-codex:codex-cli": {
        "provider": "openai-codex",
        "mode": "oauth"
      },
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.4"
      },
      "models": {
        "openai/gpt-5.1-codex": {
          "alias": "GPT"
        },
        "openai-codex/gpt-5.4": {}
      },
      "workspace": "/data/.openclaw/workspace"
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Main Agent",
        "workspace": "/data/.openclaw/workspace",
        "agentDir": "/data/.openclaw/agents/main/agent",
        "model": {
          "primary": "openai-codex/gpt-5.4"
        }
      }
    ]
  },
  "bindings": [
    {
      "type": "route",
      "agentId": "main",
      "match": {
        "channel": "telegram",
        "accountId": "default"
      }
    }
  ],
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "full",
    "media": {
      "audio": {
        "enabled": true,
        "models": [
          {
            "provider": "openai",
            "model": "gpt-4o-mini-transcribe"
          }
        ]
      }
    }
  },
  "messages": {
    "tts": {
      "auto": "tagged",
      "provider": "openai",
      "maxTextLength": 4000,
      "timeoutMs": 30000,
      "openai": {
        "model": "gpt-4o-mini-tts",
        "voice": "marin"
      },
      "modelOverrides": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "bootstrap-extra-files": {
          "enabled": true,
          "paths": [
            "hooks/bootstrap/AGENTS.md",
            "hooks/bootstrap/TOOLS.md"
          ]
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "accounts": {
        "default": {
          "name": "Telegram",
          "dmPolicy": "pairing",
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "groupPolicy": "allowlist",
          "streaming": "partial"
        }
      },
      "defaultAccount": "default",
      "streaming": "partial"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "controlUi": {
      "allowedOrigins": [
        "https://openclaw-railway-template-production-e02e.up.railway.app"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": [
      "127.0.0.1"
    ],
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "plugins": {
    "allow": [
      "telegram",
      "usage-tracker"
    ],
    "load": {
      "paths": [
        "/app/node_modules/@chrysb/alphaclaw/lib/plugin/usage-tracker"
      ]
    },
    "entries": {
      "telegram": {
        "enabled": true
      },
      "usage-tracker": {
        "enabled": true
      }
    }
  }
}
